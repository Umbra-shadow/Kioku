%% Kioku v1 architecture — render: mmdc -i architecture.mmd -o architecture.png
%% (architecture.png in this folder is generated by _gen_diagram.py, no toolchain needed)
flowchart TB
  subgraph Browser["Web Arena (web/)"]
    A1["Dual chat panes<br/>Qwen+Kioku vs Qwen raw"]
    A2["Memory Inspector<br/>pipeline · memory · lexicon · forgetting · substrate"]
  end

  subgraph Engine["FastAPI Engine (engine/)"]
    direction TB
    B0["main.py — routes + SSE"]
    B1["tenants.py — shared mind + newborns, the turn loop"]
    B2["decompose.py — understand the exchange"]
    B3["curiosity.py — self-research unknown terms"]
    B4["retrieve.py — hybrid recall + memory pack"]
    B5["forget.py — decay · consolidation · supersession"]
    B6["metrics.py — p50/p95, pack tokens"]
  end

  subgraph Qwen["Qwen Cloud — the brain (qwen.py)"]
    Q1["chat: qwen-max / qwen-plus<br/>(decompose, answer, consolidate)"]
    Q2["embeddings: text-embedding-v3"]
  end

  subgraph Substrate["Cadran virtual hardware (substrate/)"]
    direction TB
    S0["store.py seam → kiokud.rs daemon<br/>(Unix socket, line protocol)"]
