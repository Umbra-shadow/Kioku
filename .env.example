# Kioku v1 — copy to .env and fill in. .env is gitignored; no key ever in code or logs.

# Qwen Cloud / Model Studio (OpenAI-compatible endpoint) — the brain.
# International endpoint: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland endpoint:      https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-your-qwen-key-here
QWEN_MODEL=qwen-max
QWEN_EMBED_MODEL=text-embedding-v3

# Optional secondary mode: any OpenAI-compatible key gets a Kioku memory.
# Qwen stays the default and is what the demo shows. Example for Gemini:
#   GENERIC_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   GENERIC_MODEL=gemini-2.5-flash
#   GENERIC_EMBED_MODEL=text-embedding-004
GENERIC_BASE_URL=
GENERIC_API_KEY=
GENERIC_MODEL=
GENERIC_EMBED_MODEL=

# Substrate seam. KIOKU_STORE: auto | rust | py (auto prefers the kiokud daemon).
KIOKU_STORE=auto
KIOKU_SOCKET=/tmp/kiokud.sock
KIOKU_DATA_DIR=./kioku_data

# ── Researcher ───────────────────────────────────────────────────────────────
# Durable history + per-user memory. Prefer a real cloud DB (Neon Postgres) so it
# survives redeploys; leave DATABASE_URL empty to fall back to a local SQLite file.
DATABASE_URL=
# Where the SQLite file goes when DATABASE_URL is empty (default: kioku_data/research.db).
KIOKU_RESEARCH_DB=

# The web pull is free DuckDuckGo by default (no key). Set a Tavily key for
# cleaner, research-grade search + extraction.
TAVILY_API_KEY=

# NOTE: a user can also bring their OWN Qwen key in the browser (the field in the
# Researcher window). That key lives only in that window and is never persisted —
# QWEN_API_KEY above is just the server-side default/fallback.
